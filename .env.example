# Application
APP_NAME=Weather With You API
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=false

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/weatherwithyou

# External requests
REQUEST_TIMEOUT_SECONDS=10.0

# Geocoding
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=weatherwithyou/0.1.0

# Weather provider
OPEN_METEO_FORECAST_BASE_URL=https://api.open-meteo.com/v1
OPEN_METEO_ARCHIVE_BASE_URL=https://archive-api.open-meteo.com/v1

# Google Maps enrichment
GOOGLE_MAPS_EMBED_API_KEY=
GOOGLE_MAPS_EMBED_BASE_URL=https://www.google.com/maps/embed/v1

# YouTube enrichment
YOUTUBE_DATA_API_KEY=
YOUTUBE_DATA_API_BASE_URL=https://www.googleapis.com/youtube/v3
YOUTUBE_MAX_RESULTS=3

# Gemini pun enrichment
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
